# Default Backend VPS URL (e.g., your Coolify app URL)
# If set, the dashboard will pre-fill this URL on startup.
VITE_DEFAULT_BACKEND_URL=https://api.yourdomain.com

# Default Admin API Key (matches ADMIN_API_KEY in backend .env)
# If set, the dashboard will pre-fill this key on startup.
# Leave blank in public repositories to avoid exposure.
VITE_DEFAULT_API_KEY=

# Dashboard Lock Passphrase
# If set, the console will require this password to unlock.
# Leave blank to disable the password lock screen.
VITE_DASHBOARD_PASSWORD=
