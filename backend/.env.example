# Meta Webhook Verification Token (This can be any random secret string you choose)
# You will enter this exact token in the Facebook Developer Portal when setting up the Webhook.
META_VERIFY_TOKEN=my_super_secret_token_123

# Meta Graph API Page Access Token or User Access Token with messaging/instagram permissions
META_ACCESS_TOKEN=your_meta_access_token_here

# Server Port (default is 8080)
PORT=8080

# Logging Level (info, warn, error, debug, trace)
RUST_LOG=info,instragram_automation=debug
